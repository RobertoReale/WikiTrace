{
  "manifest_version": 2,
  "name": "WikiTrace",
  "version": "1.1.0",
  "description": "Track, archive and visualise every Wikipedia page you visit.",

  "browser_specific_settings": {
    "gecko": {
      "id": "wikitrace@reale2006",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "storage",
    "unlimitedStorage",
    "webNavigation",
    "tabs",
    "https://*.wikipedia.org/*"
  ],

  "web_accessible_resources": ["lib/d3.min.js"],

  "background": {
    "scripts": ["lib/browser-polyfill.min.js", "background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["https://*.wikipedia.org/wiki/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "WikiTrace",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
