{
  "manifest_version": 3,
  "name": "WikiTrace",
  "version": "1.1.0",
  "description": "Track, archive and visualise every Wikipedia page you visit.",

  "permissions": [
    "storage",
    "unlimitedStorage",
    "webNavigation",
    "tabs"
  ],

  "host_permissions": [
    "https://*.wikipedia.org/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["lib/d3.min.js"],
      "matches": ["https://*.wikipedia.org/*"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://*.wikipedia.org/wiki/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WikiTrace",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
